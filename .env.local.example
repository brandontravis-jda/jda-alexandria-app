# ================================
# Auth.js v5 + Microsoft Entra ID
# ================================
AUTH_SECRET=                          # Generate with: npx auth secret
AUTH_MICROSOFT_ENTRA_ID_ID=           # Application (client) ID from Azure
AUTH_MICROSOFT_ENTRA_ID_SECRET=       # Client secret value from Azure
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=    # Directory (tenant) ID from Azure

# ================================
# Database
# ================================
DATABASE_URL=                         # PostgreSQL connection string (Railway)

# ================================
# Sanity
# ================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# ================================
# Site
# ================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
